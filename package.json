{
  "name": "pi-web-site",
  "version": "0.0.0",
  "private": true,
  "description": "pi-web 官网与文档站（落地页 + Nextra 文档）。文档内容从 pi-web 仓 docs/product 同步，pi-web 为唯一来源。",
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "predev": "node scripts/sync-content.mjs",
    "dev": "next dev",
    "prebuild": "node scripts/sync-content.mjs",
    "build": "next build",
    "build:site": "node scripts/build-site.mjs",
    "start": "next start",
    "clean": "rm -rf .next out pages/docs"
  },
  "dependencies": {
    "next": "^14.2.5",
    "nextra": "^3.0.0",
    "nextra-theme-docs": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=18.18.0"
  }
}
